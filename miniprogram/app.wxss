page {
  background: #f4f7fb;
  color: #111827;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.section-subtitle {
  color: #6b7280;
  font-size: 24rpx;
}

.primary-btn {
  background: #2563eb;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.ghost-btn {
  background: #eff6ff;
  color: #2563eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.danger-btn {
  background: #ef4444;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-available {
  background: #dcfce7;
  color: #15803d;
}

.tag-booked {
  background: #fee2e2;
  color: #b91c1c;
}

.tag-completed {
  background: #e0e7ff;
  color: #4338ca;
}

.tag-full {
  background: #fef3c7;
  color: #b45309;
}

.tag-closed {
  background: #f3f4f6;
  color: #6b7280;
}

.field {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.field-input,
.field-textarea {
  width: 100%;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 26rpx 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  min-height: 96rpx;
}

.field-textarea {
  min-height: 240rpx;
}

.empty-text {
  color: #9ca3af;
  text-align: center;
  padding: 26rpx 0;
}

.list-gap {
  display: flex;
 flex-direction: column;
  gap: 20rpx;
}

.muted {
  color: #6b7280;
}
