<view class="page">
  <view class="card">
    <view class="section-title">我的本周预约</view>
    <view class="section-subtitle">这里展示你本周值班日期的预约记录。</view>
    <view wx:if="{{loading}}" class="empty-text">加载中...</view>
    <view wx:elif="{{weeklyAppointments.length === 0}}" class="empty-text">本周无预约</view>
    <view wx:else class="list-gap top-gap">
      <block wx:for="{{weeklyAppointments}}" wx:key="id">
        <view class="record-item">
          <view class="record-top">
            <view class="record-title">{{item.serviceDateLabel}} {{item.slotLabel}}</view>
            <view class="tag tag-{{item.status === 'completed' ? 'completed' : (item.status === 'cancelled' ? 'closed' : 'booked')}}">{{item.statusText}}</view>
          </view>
          <view class="record-desc">类型：{{item.appointmentType || '未填写'}}</view>
          <view class="record-desc">值班组别：{{item.groupName || '未排班'}}</view>
          <view class="record-desc">姓名：{{item.name}}</view>
          <view class="record-desc">手机号：{{item.phoneMasked}}</view>
          <view class="record-desc">需求：{{item.request}}</view>
          <view wx:if="{{item.closedBy}}" class="record-desc">结单人：{{item.closedBy}}</view>
          <view wx:if="{{item.status === 'booked'}}" class="action-area">
            <button
              class="{{item.canCancel ? 'ghost-btn' : 'disabled-action-btn'}}"
              loading="{{cancelingId === item.id}}"
              bindtap="cancelAppointment"
              data-id="{{item.id}}"
              data-can-cancel="{{item.canCancel}}"
            >
              取消预约
            </button>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="section-title">查询历史预约</view>
    <view class="section-subtitle">可先选择值班日期后查询，也可一键查看全部历史预约。</view>

    <view wx:if="{{loading}}" class="empty-text">加载中...</view>
    <view wx:elif="{{historyAppointments.length === 0}}" class="empty-text">暂无历史预约</view>
    <view wx:else>
      <view class="field">
        <text class="field-label">选择值班日期</text>
        <picker mode="selector" range="{{historyDateOptions}}" range-key="serviceDateLabel" bindchange="chooseHistoryDate">
          <view class="picker-field">
            <text wx:if="{{selectedHistoryDateLabel}}">{{selectedHistoryDateLabel}}</text>
            <text wx:else>请选择值班日期</text>
          </view>
        </picker>
      </view>

      <view class="query-btn-row">
        <button class="primary-btn query-btn" bindtap="queryBySelectedDate">按日期查询</button>
        <button class="ghost-btn query-btn" bindtap="queryAllHistory">查询全部预约</button>
      </view>

      <view wx:if="{{historyQueryMode === 'none'}}" class="empty-text">请选择值班日期后进行查询，或点击右侧按钮查看全部历史预约。</view>
      <view wx:elif="{{queryResults.length === 0}}" class="empty-text">{{historyEmptyText}}</view>
      <view wx:else class="list-gap top-gap">
        <block wx:for="{{queryResults}}" wx:key="id">
          <view class="record-item">
            <view class="record-top">
              <view class="record-title">{{item.serviceDateLabel}} {{item.slotLabel}}</view>
              <view class="tag tag-{{item.status === 'completed' ? 'completed' : (item.status === 'cancelled' ? 'closed' : 'booked')}}">{{item.statusText}}</view>
            </view>
            <view class="record-desc">类型：{{item.appointmentType || '未填写'}}</view>
            <view class="record-desc">值班组别：{{item.groupName || '未排班'}}</view>
            <view class="record-desc">姓名：{{item.name}}</view>
            <view class="record-desc">手机号：{{item.phoneMasked}}</view>
            <view class="record-desc">需求：{{item.request}}</view>
            <view wx:if="{{item.closedBy}}" class="record-desc">结单人：{{item.closedBy}}</view>
            <view wx:if="{{item.status === 'booked'}}" class="action-area">
              <button
                class="{{item.canCancel ? 'ghost-btn' : 'disabled-action-btn'}}"
                loading="{{cancelingId === item.id}}"
                bindtap="cancelAppointment"
                data-id="{{item.id}}"
                data-can-cancel="{{item.canCancel}}"
              >
                取消预约
              </button>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
