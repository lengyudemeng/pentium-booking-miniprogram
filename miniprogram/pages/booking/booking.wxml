<view class="page">
  <view class="card">
    <view class="section-title">预约服务</view>
  </view>

  <view class="card nav-card" bindtap="goCreatePage">
    <view class="nav-card-head">
      <view>
        <view class="nav-card-title">值班预约</view>
        <view class="nav-card-desc">选择日期、时段并填写预约信息，提交值班预约</view>
      </view>
      <view class="nav-card-arrow">></view>
    </view>
  </view>

  <view class="card nav-card" bindtap="goQueryPage">
    <view class="nav-card-head">
      <view>
        <view class="nav-card-title">预约查询</view>
        <view class="nav-card-desc">查看我的预约记录，对预约进行管理</view>
      </view>
      <view class="nav-card-arrow">></view>
    </view>
  </view>
</view>
