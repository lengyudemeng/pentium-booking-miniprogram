.nav-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.nav-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.nav-card-desc {
  margin-top: 10rpx;
  color: #6b7280;
  line-height: 1.8;
}

.nav-card-arrow {
  color: #2563eb;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}
