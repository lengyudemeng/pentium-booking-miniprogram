.hero-card {
  overflow: hidden;
  padding: 0;
}

.hero-text {
  padding: 28rpx 28rpx 10rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: #4b5563;
  line-height: 1.6;
}

.hero-btn {
  margin-top: 24rpx;
}

.hero-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.top-gap {
  margin-top: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stat-item {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 26rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 10rpx;
  color: #6b7280;
}

.blue {
  color: #2563eb;
}

.orange {
  color: #ea580c;
}

.green {
  color: #16a34a;
}

.schedule-item {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 24rpx;
}

.schedule-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-title {
  font-size: 30rpx;
  font-weight: 700;
}

.schedule-desc,
.schedule-count {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.slot-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.slot-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.slot-pill-available {
  background: #dcfce7;
  color: #15803d;
}

.slot-pill-booked {
  background: #fee2e2;
  color: #b91c1c;
}

.slot-pill-completed {
  background: #e0e7ff;
  color: #4338ca;
}

.slot-pill-full {
  background: #fef3c7;
  color: #b45309;
}

.slot-pill-closed {
  background: #f3f4f6;
  color: #6b7280;
}

.info-line {
  color: #374151;
  line-height: 1.8;
  margin-bottom: 8rpx;
}
